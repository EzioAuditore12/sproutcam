{
  "name": "sproutcam",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc && tsup",
    "start:dev": "node --import=tsx --watch src/index.ts",
    "start:prod": "node dist/index.js",
    "better-auth:generate": "pnpm dlx @better-auth/cli generate --output ./src/db/schemas/auth.schema.ts",
    "db:generate:migration": "pnpm exec drizzle-kit generate",
    "db:migrate": "pnpm exec drizzle-kit migrate",
    "db:studio": "pnpm exec drizzle-kit studio",
    "seed:badges": "node --import=tsx seeders/badge.seeder.ts",
    "seed:missions": "node --import=tsx seeders/mission.seeder.ts",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@sapphire/snowflake": "^3.5.5",
    "@scalar/express-api-reference": "^0.10.4",
    "better-auth": "^1.6.20",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-error-toolkit": "^1.2.1",
    "express-rate-limit": "^8.5.2",
    "express-zod-safe": "^3.2.1",
    "form-data": "^4.0.6",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "mailgun.js": "^13.2.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "prettier-eslint": "^17.1.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "outDir": "dist",
    "format": [
      "esm",
      "cjs"
    ],
    "target": "es2020",
    "sourcemap": true,
    "clean": true,
    "dts": true,
    "splitting": false,
    "skipNodeModulesBundle": true
  }
}
